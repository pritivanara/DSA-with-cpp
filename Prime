//check whether if the given number is prime or non prime.

#include <iostream>
using namespace std;

int main() {
 int Num, i;

 cout << "Enter a number: ";
 cin >> Num;

 if(Num <= 1) {
  cout << "Not a Prime number.";
  return 0;
 }

 for(i = 2; i <= Num / 2; i++) {
  if(Num % i == 0) {
   cout << "Not a Prime number.";
   return 0;
  }
 }

 cout << "The number is Prime.";

 return 0;
}
