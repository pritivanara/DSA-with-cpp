// Greatest Common Divisor(GCD) of two numbers.

#include <iostream>
using namespace std;

int main() {
 int Num1, Num2, Temp;

 cout << "Enter two numbers: ";
 cin >> Num1 >> Num2;

 while(Num2 != 0) {
  Temp = Num2;
  Num2 = Num1 % Num2;
  Num1 = Temp;
 }

 cout << "GCD is: " << Num1;

 return 0;
}
