//check whether if the string is plaindrome or not.

#include <iostream>
#include <string>
using namespace std;

int main() {
 string Str;
 string Rev = "";
 int Len, i;

 cout << "Enter a string: ";
 getline(cin, Str);

 Len = Str.length();

 for(i = Len - 1; i >= 0; i--) {
  Rev = Rev + Str[i];
 }

 if(Str == Rev) {
  cout << "The string is a Palindrome.";
 } else {
  cout << "The string is Not a Palindrome.";
 }

 return 0;
}
